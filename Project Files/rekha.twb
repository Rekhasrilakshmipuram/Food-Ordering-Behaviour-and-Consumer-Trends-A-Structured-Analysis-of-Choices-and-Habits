                <story-points>
                  <story-point caption='American cuisine generates the highest revenue.&#10;Japanese cuisine ranks second.&#10;French cuisine has the highest average order value.&#10;Vietnamese cuisine has the lowest average order value.' captured-sheet='Revenue by Cuisine' id='1' />
