                <story-points>
                  <story-point caption='American and Japanese cuisines receive the highest number of ratings.&#10;Most ratings are positive (4 and 5 stars).&#10;Higher customer satisfaction can improve customer retention.' captured-sheet='Ratings by Cuisine' id='1' />
