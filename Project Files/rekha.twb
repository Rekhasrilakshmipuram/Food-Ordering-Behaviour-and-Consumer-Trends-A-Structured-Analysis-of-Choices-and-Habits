              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='This project analyzes food ordering data using Tableau to understand customer preferences, revenue generation, restaurant performance, delivery efficiency, and customer ratings. The insights help businesses improve customer satisfaction and operational performance.' captured-sheet='Dashboard 1' id='1' />
