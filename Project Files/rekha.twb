              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Description:&#10;&#10;Average delivery time ranges between 22–26 minutes across cuisines.&#10;Vietnamese cuisine has the longest average delivery time.&#10;Korean cuisine has one of the shortest average delivery times.&#10;Optimizing delivery time can further improve customer satisfaction.&#10;&#10;Conclusion:&#10;&#10;American and Japanese cuisines generate the highest revenue and order volume. Weekend demand is significantly higher than weekday demand, and top restaurants play a major role in overall sales. Maintaining quick delivery and high customer satisfaction can help increase customer loyalty and business growth.' captured-sheet='Average Delivery Time by Cuisine' id='1' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{8706DD94-4BF5-45FD-B8A2-96F51C32CFDA}' />
    </dashboard>
